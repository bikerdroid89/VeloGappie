<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_bike_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#99000000"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:id="@+id/widget_stats_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/widget_battery_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_widget_battery"

                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#DD000000" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_divider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="#14000000"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/widget_speed_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_widget_speed"

                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#DD000000" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#55000000"
        android:fontFamily="sans-serif"
        android:gravity="center" />

</LinearLayout>
